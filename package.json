{
  "name": "md2pdf",
  "version": "2.0.0",
  "description": "Production-ready Markdown to PDF converter with Mermaid diagram support",
  "main": "src/index.js",
  "bin": {
    "md2pdf": "./src/cli/index.js"
  },
  "scripts": {
    "start": "node src/cli/index.js",
    "dev": "node src/cli/index.js examples/sample.md --watch",
    "test": "node src/cli/index.js examples/sample.md -o examples/output.pdf",
    "lint": "eslint src/"
  },
  "keywords": [
    "markdown",
    "pdf",
    "mermaid",
    "converter",
    "cli",
    "diagrams"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "chalk": "^4.1.2",
    "chokidar": "^3.6.0",
    "commander": "^12.0.0",
    "glob": "^10.3.10",
    "gray-matter": "^4.0.3",
    "highlight.js": "^11.9.0",
    "marked": "^12.0.0",
    "ora": "^5.4.1",
    "puppeteer": "^22.0.0"
  }
}
